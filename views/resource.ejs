<% layout('layouts/boilerplate') %>

<link rel="stylesheet" href="/css/resource.css">

<div class="container mt-4 pb-5">
  <div class="resource-viewer">

    <!-- HEADER -->
    <div class="d-flex justify-content-between align-items-center mb-3">
      <div>
        <h4><%= item.title %></h4>
        <p>
          <span class="badge bg-primary"><%= item.type %></span>
          <span class="text-muted"><%= item.subject %> · <%= item.year %></span>
        </p>
        <p>
          Uploaded by <strong><%= item.owner?.username %></strong>
        </p>
      </div>

      <div>
        👁️ <%= item.views %> views
      </div>
    </div>

    <% if(item.file && item.file.url) { %>

      <% const url = item.file.url; %>

      <!-- ✅ PREVIEW -->
      <div style="width:100%; height:600px; border:1px solid #ddd; border-radius:8px; overflow:hidden; background:#f5f5f5;">
        <iframe 
          src="https://docs.google.com/gview?url=<%= url %>&embedded=true"
          width="100%" 
          height="100%"
          style="border:none;"
          allowfullscreen>
        </iframe>
      </div>

      <p class="text-muted mt-1" style="font-size:0.8rem;">
        If preview doesn’t load, 
        <a href="<%= url %>" target="_blank">open file directly</a>.
      </p>

      <!-- ✅ DOWNLOAD -->
      <div class="mt-3">
        <a href="<%= url %>" download class="btn btn-glb-primary w-100">
          Download File
        </a>
      </div>

    <% } else { %>
      <div class="alert alert-warning">No file found</div>
    <% } %>

    <!-- DELETE -->
    <% if(currentUser && (currentUser.role === 'admin' || String(item.owner?._id) === String(currentUser._id))) { %>
      <form action="/delete/<%= item._id %>?_method=DELETE" method="POST" class="mt-3">
        <button class="btn btn-danger w-100" onclick="return confirm('Delete this resource?')">
          Delete Resource
        </button>
      </form>
    <% } %>

  </div>
</div>