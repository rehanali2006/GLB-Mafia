<% layout('layouts/boilerplate') %>

<div class="container mt-4">

  <h3><%= item.title %></h3>
  <p><%= item.subject %> • <%= item.year %></p>

  <% if(item.file && item.file.url) { %>

    <% const url = item.file.url; %>

    <!-- ✅ PREVIEW -->
    <div style="height:600px;">
      <iframe 
        src="https://docs.google.com/gview?url=<%= url %>&embedded=true"
        width="100%" 
        height="100%">
      </iframe>
    </div>

    <!-- ✅ DOWNLOAD -->
    <div class="mt-3">
      <a href="<%= url %>" download class="btn btn-primary">
        Download File
      </a>
    </div>

  <% } else { %>
    <p>No file found</p>
  <% } %>

</div>