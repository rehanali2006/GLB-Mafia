<% layout('layouts/boilerplate') %>
<link rel="stylesheet" href="/css/auth.css">

<div class="auth-wrapper">
  <div class="auth-card">

    <!--Icon-->
    <div class="auth-icon">🎓</div>
    <h2 class="auth-title">Create Account</h2>
    <p class="auth-sub">Join GLB Mafia today</p>

    <form action="/auth/signup" method="POST" class="needs-validation" novalidate>

      <!--Username-->
      <div class="mb-3">
        <label class="form-label">Username</label>
        <div class="input-group">
          <span class="input-group-text"><i class="bi bi-person-fill"></i></span>
          <input
            type="text"
            name="username"
            class="form-control"
            placeholder="coolstudent42"
            minlength="3"
            maxlength="30"
            required
          >
        </div>
        <div class="invalid-feedback">Username must be 3–30 characters</div>
      </div>

      <!--Email-->
      <div class="mb-3">
        <label class="form-label">Email Address</label>
        <div class="input-group">
          <span class="input-group-text"><i class="bi bi-envelope-fill"></i></span>
          <input
            type="email"
            name="email"
            class="form-control"
            placeholder="you@example.com"
            required
          >
        </div>
        <div class="invalid-feedback">Please enter a valid email</div>
      </div>

      <!--Password-->
      <div class="mb-3">
        <label class="form-label">Password</label>
        <div class="input-group">
          <span class="input-group-text"><i class="bi bi-lock-fill"></i></span>
          <input
            type="password"
            name="password"
            id="passwordInput"
            class="form-control"
            placeholder="Min 6 characters"
            minlength="6"
            required
          >
          <button class="input-group-text bg-white border-start-0" type="button" id="togglePass">
            <i class="bi bi-eye" id="eyeIcon"></i>
          </button>
        </div>
        <div class="invalid-feedback">Password must be at least 6 characters</div>
      </div>

      <!--Confirm Password-->
      <div class="mb-4">
        <label class="form-label">Confirm Password</label>
        <div class="input-group">
          <span class="input-group-text"><i class="bi bi-shield-lock-fill"></i></span>
          <input
            type="password"
            name="confirmPassword"
            id="confirmPasswordInput"
            class="form-control"
            placeholder="Repeat password"
            required
          >
        </div>
        <div class="invalid-feedback" id="confirmFeedback">Passwords must match</div>
      </div>

      <!--Submit-->
      <button type="submit" class="btn btn-glb-primary w-100 py-2">
        <i class="bi bi-person-check me-2"></i>Create Account
      </button>

    </form>

    <!--Divider-->
    <div class="auth-divider"><span>or</span></div>

    <p class="text-center mb-0 auth-link-text">
      Already have an account?
      <a href="/auth/login" class="auth-link">Log in</a>
    </p>

  </div>
</div>

<script src="/js/formValidation.js"></script>
<script>
  const toggleBtn = document.getElementById('togglePass');
  const passInput = document.getElementById('passwordInput');
  const eyeIcon = document.getElementById('eyeIcon');
  toggleBtn.addEventListener('click', () => {
    const isPass = passInput.type === 'password';
    passInput.type = isPass ? 'text' : 'password';
    eyeIcon.className = isPass ? 'bi bi-eye-slash' : 'bi bi-eye';
  });

 
  document.querySelector('form').addEventListener('submit', (e) => {
    const p = document.getElementById('passwordInput').value;
    const c = document.getElementById('confirmPasswordInput').value;
    if (p !== c) {
      e.preventDefault();
      e.stopPropagation();
      document.getElementById('confirmPasswordInput').classList.add('is-invalid');
      document.getElementById('confirmFeedback').textContent = 'Passwords do not match!';
    }
  });
</script>
