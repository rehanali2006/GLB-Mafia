<% layout('layouts/boilerplate') %>
<link rel="stylesheet" href="/css/chooseClass.css">

<div class="container mt-5 pb-5">

  <!-- Heading -->
  <div class="text-center mb-5">
    <div class="year-icon-wrap mx-auto mb-3">
      <img src="https://cdn-icons-png.flaticon.com/512/7092/7092289.png" alt="First Year" class="year-hero-img">
    </div>
    <h2 class="page-heading">🎓 First Year</h2>
    <p class="page-sub">First Year is organized by <strong>Class Section</strong> — choose yours below</p>
  </div>

  <!-- Info banner -->
  <div class="info-banner mb-4">
    <i class="bi bi-info-circle-fill me-2"></i>
    First year students are grouped into class sections (A, B, C …) rather than branches.
  </div>

  <!-- Section Grid -->
  <div class="row g-3 justify-content-center">

    <% const sections = 'ABCDEFGHIJKLMNOPQRSTUVWXYZ'.split(''); %>
    <% sections.forEach(sec => { %>
      <div class="col-4 col-sm-3 col-md-2">
        <a href="/home/First/ALL?section=<%= sec %>" class="section-card">
          <span class="section-letter"><%= sec %></span>
          <span class="section-label">Section <%= sec %></span>
        </a>
      </div>
    <% }) %>

  </div>

  <!-- Back -->
  <div class="text-center mt-5">
    <a href="/" class="btn btn-outline-secondary">
      <i class="bi bi-arrow-left me-1"></i> Back to Years
    </a>
  </div>

</div>
