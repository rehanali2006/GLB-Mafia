<% layout('layouts/boilerplate') %>

<link rel="stylesheet" href="/css/resource.css">

<style>
.preview-thumb {
  width: 100%;
  height: 160px;
  object-fit: cover;
  border-radius: 10px;
  border: 1px solid #e0e0e0;
  background: #f5f5f5;
  transition: transform 0.2s ease, box-shadow 0.2s ease;
}
.preview-thumb:hover {
  transform: scale(1.02);
  box-shadow: 0 4px 16px rgba(0,0,0,0.15);
}
.preview-placeholder {
  width: 100%;
  height: 160px;
  border-radius: 10px;
  background: linear-gradient(135deg, #ffeaea 0%, #fff0f0 100%);
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  border: 1px solid #f5c6c6;
  transition: transform 0.2s ease;
}
.preview-placeholder:hover {
  transform: scale(1.02);
}
</style>

<div class="container mt-4 pb-5">

  <% if (data.length === 0) { %>
    <div class="text-center mt-5">
      <h4>No resources found 😕</h4>
    </div>
  <% } %>

  <div class="row g-4">
    <% data.forEach(item => { %>
      <div class="col-md-6 col-lg-4">
        <div class="resource-card p-3 text-center">

          <!-- 📄 PREVIEW THUMBNAIL -->
          <a href="/resource/<%= item._id %>" style="text-decoration:none; color:inherit;">
            <% if (item.file && item.file.url) { %>
              <%
                // Generate Cloudinary thumbnail from the raw PDF
                // Cloudinary raw PDFs: replace /raw/upload/ with /image/upload/ and append .jpg
                // Also add transformation for first-page thumbnail
                let thumbUrl = null;
                const rawUrl = item.file.url;
                if (rawUrl && rawUrl.includes('cloudinary.com')) {
                  // Convert raw PDF URL to image thumbnail URL (first page)
                  thumbUrl = rawUrl
                    .replace('/raw/upload/', '/image/upload/w_400,h_220,c_fill,pg_1,q_70,f_jpg/')
                    .replace(/\.pdf$/i, '.jpg');
                }
              %>
              <% if (thumbUrl) { %>
                <img
                  src="<%= thumbUrl %>"
                  alt="<%= item.title %> preview"
                  class="preview-thumb mb-2"
                  onerror="this.style.display='none'; this.nextElementSibling.style.display='flex';"
                />
                <div class="preview-placeholder mb-2" style="display:none;">
                  <i class="bi bi-file-earmark-pdf" style="font-size:50px; color:#e53935;"></i>
                  <p class="mt-1 mb-0 small fw-semibold text-muted">Open Assignment</p>
                </div>
              <% } else { %>
                <div class="preview-placeholder mb-2">
                  <i class="bi bi-file-earmark-pdf" style="font-size:50px; color:#e53935;"></i>
                  <p class="mt-1 mb-0 small fw-semibold text-muted">Open Assignment</p>
                </div>
              <% } %>
            <% } else { %>
              <div class="preview-placeholder mb-2">
                <i class="bi bi-file-earmark" style="font-size:50px; color:#aaa;"></i>
                <p class="mt-1 mb-0 small text-muted">No file</p>
              </div>
            <% } %>
          </a>

          <!-- 📌 TITLE -->
          <h6 class="mb-2"><%= item.title %></h6>

          <!-- 📌 META -->
          <p class="mb-1">
            <span class="badge bg-primary"><%= item.type %></span>
          </p>
          <p class="text-muted small mb-2">
            <%= item.subject %> · <%= item.year %> Year
          </p>

          <!-- 👤 UPLOADED BY -->
          <p class="small mb-1">
            <i class="bi bi-person-circle me-1"></i>
            <%= item.owner?.username || "Unknown" %>
          </p>

          <!-- 👁️ VIEWS -->
          <p class="small text-muted mb-3">
            <i class="bi bi-eye me-1"></i>
            <%= item.views %> views
          </p>

          <!-- 🔗 OPEN BUTTON -->
          <a href="/resource/<%= item._id %>" class="btn btn-glb-primary btn-sm w-100">
            <i class="bi bi-eye me-2"></i>View Resource
          </a>

        </div>
      </div>
    <% }) %>
  </div>

</div>
